-->
<configuration>
	<configSections>
		<sectionGroup name="devExpress">
			<section name="settings" type="DevExpress.Web.SettingsConfigurationSection, DevExpress.Web.v21.2, Version=21.2.15.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" requirePermission="false" />
			<section name="compression" type="DevExpress.Web.CompressionConfigurationSection, DevExpress.Web.v21.2, Version=21.2.15.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" requirePermission="false" />
			<section name="themes" type="DevExpress.Web.ThemesConfigurationSection, DevExpress.Web.v21.2, Version=21.2.15.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" requirePermission="false" />
			<section name="errors" type="DevExpress.Web.ErrorsConfigurationSection, DevExpress.Web.v21.2, Version=21.2.15.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" requirePermission="false" />
			<section name="resources" type="DevExpress.Web.ResourcesConfigurationSection, DevExpress.Web.v21.2, Version=21.2.15.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" requirePermission="false" />
			<section name="bootstrap" type="DevExpress.Web.Bootstrap.BootstrapConfigurationSection, DevExpress.Web.Bootstrap.v21.2, Version=21.2.15.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" requirePermission="false" />
		</sectionGroup>
	</configSections>
	<connectionStrings>
		<add name="IMSDBConnectionString" connectionString="Data source=.;initial catalog=IMS-DB; Integrated Security=SSPI; MultipleActiveResultSets=True; Persist Security Info=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
		<add name="IMSAccConnectionString" connectionString="Data Source=.; Initial Catalog=IMS-DB; Integrated Security=SSPI; MultipleActiveResultSets=True; Persist Security Info=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
		<add name="CIMSDBConnectionString" connectionString="Data source=.; initial catalog=IMS-DB; Integrated Security=SSPI; MultipleActiveResultSets=True; Persist Security Info=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
		<add name="AttachConString" connectionString="Data Source=.;Initial Catalog=AttachDB;Integrated Security =SSPI;MultipleActiveResultSets=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
		<add name="IMS-DBConnectionString" connectionString="Data Source=.;Initial Catalog=IMS-DB;Integrated Security=True;Persist Security Info=True;MultipleActiveResultSets=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
		<add name="AttachDBConnectionString" connectionString="Data Source=.;Initial Catalog=AttachDB;Integrated Security=True;MultipleActiveResultSets=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
		<add name="AttachDB" connectionString="Data Source=.;Initial Catalog=AttachDB;Integrated Security = SSPI;MultipleActiveResultSets=True; Connection Timeout=300;" providerName="System.Data.SqlClient" />
	</connectionStrings>
	<appSettings>
		<add key="ReportServerEndPoint" value="http://localhost/ReportServer/" />
		
		<!--<add key="SSRSUserName" value="ggins.ly\SRV_WebUser" />
		<add key="SSRSPassword" value="SecurePTGS@1" />-->
		<add key="ReportsPath" value="/IMSReports/" />
		
		<add key="SMSapiUrl" value="https://isend.com.ly/api/http/sms/send" />
		<add key="SMSTokenKey" value="??" />
		<add key="Sender_id" value="??" />

		<add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
		
		<!-- LIFO API Configuration -->
		<add key="ApiBaseUrl" value="https://prodapi.lifo.ly/" />
		<add key="ApiUsername" value="*" />
		<add key="ApiPassword" value="*" />
		
		<add key="AppN" value="" />
		<add key="owin:AutomaticAppStartup" value="false" />
		<add key="vs:EnableBrowserLink" value="true" />
	</appSettings>
	<!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.5.2" />
      </system.Web>
  -->
	<system.web>
		<roleManager enabled="true" />
		<sessionState timeout="45" />
		<!--<customErrors defaultRedirect="~/SystemManage/ErrPage.aspx" mode="Off"/>-->
		<customErrors mode="Off" />
		<httpCookies requireSSL="true" httpOnlyCookies="true" lockItem="true" />
		<!--<httpRuntime enableVersionHeader="false" targetFramework="4.5" />-->
		<!-- Increase request limits for large PDFs -->
		<httpRuntime targetFramework="4.7.2" maxRequestLength="10240" executionTimeout="300" />
