<%@ Page Title="Chart Of Accounts" Language="vb" AutoEventWireup="false" ValidateRequest="false" MasterPageFile="~/Main.master" CodeBehind="ChartOfAccounts.aspx.vb" Inherits="ChartOfAccounts" %>

<%@ Register Assembly="DevExpress.Web.ASPxTreeList.v21.2, Version=21.2.3.0, Culture=neutral, PublicKeyToken=b88d1754d700e49a" Namespace="DevExpress.Web.ASPxTreeList" TagPrefix="dx" %>
<asp:Content ID="Content1" ContentPlaceHolderID="MainContent" runat="server">
    <div>
        <script>
            function OnEndCallBack(s, e) {
                // debugger;
                //if (cpMyAttribute == 'PrintLedger') {
                //alert(s.cpMyAttribute);
                let hdr = s.cpResult
                let mhdr = 'طباعة - '
                popup.SetHeaderText(mhdr.concat(hdr));
                popup.SetContentHtml(null);
                popup.SetContentUrl(s.cpNewWindowUrl);

                var width = Math.max(0, document.documentElement.clientWidth) * 0.9;
                var height = Math.max(0, document.documentElement.clientHeight) * 0.8;
                popup.SetWidth(width);
                popup.SetSize(width, height);
                popup.Show();
                //}
                s.cpMyAttribute = ''
                s.cpNewWindowUrl = null
            }

            function CoaOnEndCallBack(s, e) {
                //alert(s.cpMyAttribute);
                if (s.cpNewWindowUrl != null && s.cpMyAttribute == 'PrintLedgerBulk') {
                    //window.open(s.cpNewWindowUrl);
                    //PrintPop.SetSize(1000, 800);
                    let hdr = s.cpResult;
                    let mhdr = 'طباعة - ';
                    popup.SetHeaderText(mhdr.concat(hdr));
                    popup.SetContentHtml(null);
                    popup.SetContentUrl(s.cpNewWindowUrl);
                    popup.SetSize(Math.max(0, document.documentElement.clientWidth) * 0.95, Math.max(0, document.documentElement.clientHeight) * 0.95);
                    popup.Show();
                }
                else {
                    //alert("لم يتم اختيار أي حسابات");
                }
                s.cpMyAttribute = ''
                s.cpNewWindowUrl = null
            }

            function puOnInit(s, e) {
                AdjustSize();
                ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                    AdjustSize();
                    if (s.IsVisible())
                        s.UpdatePosition();
                });
            }

            function AdjustSize() {
                var width = Math.max(0, document.documentElement.clientWidth) * 0.6;
                var height = Math.max(0, document.documentElement.clientHeight) * 0.5;
                popup.SetWidth(width);
                popup.SetSize(width, height);
            }
            //function SelectAndClosePopup() {
            //    popup.Hide();
            //    coa.Refresh();
            //    //AccMoveGrid.Refresh();
            //}
            function SelectAndClosePopup() {
                popup.Hide();
                coa.PerformCallback();
                //AccMoveGrid.Refresh();
            }
            function OnToolbarItemClick(s, e) {
                if (IsCustomExportToolbarCommand(e.item.name)) {
                    e.processOnServer = true;
                    //cb.PerformCallback();
                }
                }


            function IsCustomExportToolbarCommand(command) {
                //alert(command);
                return command == "CustomLedger"
                //|| command == "ExtraSearch";
                //command == "CustomExportToXLS" || command == "CustomExportToXLSX" ||
            }
