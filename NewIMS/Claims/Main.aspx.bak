    <asp:SqlDataSource ID="SqlDataSource1" runat="server" 
        ConnectionString="<%$ ConnectionStrings:IMSDBConnectionString %>" 
        ProviderName="System.Data.SqlClient"        
        SelectCommand="select MainClaimFile.ClmNo, mainclaimfile.PolNo, mainclaimfile.Status,(SELECT Max(v) 
   FROM (VALUES (MainClaimFile.ClmDate),(Estimation.date),(esal.esd)) AS value(v)) as DT
, Estimation.value, Sn, MainClaimFile.Branch,branchinfo.BranchName,esal.net,esal.esd,Estimation.date,MainClaimFile.ClmSysDate,esal.disd,
        isnull(NetPrm.PolNo,rtrim(PolicyFile.polno)+'-'+rtrim(mainclaimfile.clmno)) AS CLM, MainClaimFile.EndNo, MainClaimFile.LoadNo,
rtrim(substring(NetPrm.PolNo,15,len(rtrim(NetPrm.polno)))),CustomerFile.CustName,
CASE WHEN EXISTS (
    SELECT PolNo
    FROM NetPrm
    WHERE (PolNo = rtrim(Estimation.polno) + '-' + rtrim(Estimation.clmno) and round(Estimation.value,3)=round(Net,3)))
THEN CAST(1 AS BIT)
ELSE CAST(0 AS BIT)
 END as Outstanding,
 CASE WHEN EXISTS (
    SELECT PolNo
    FROM NetPrm
     WHERE (substring(NetPrm.PolNo,15,len(rtrim(NetPrm.polno)))) = rtrim(esal.clmno) and NetPrm.Total<>-1 and  esal.branch=NetPrm.Br)
THEN CAST(1 AS BIT)
ELSE CAST(0 AS BIT)
 END as Payed,
 case when  esal.net is not NULL 
 then
 'سداد'
 else
 'تقدير احتياطي'
 END as STATE,
RTRIM(MainClaimFile.ClmNo) + '&EndNo=' + LTRIM(MainClaimFile.EndNo) + '&LoadNo=' + LTRIM(MainClaimFile.LoadNo) 
                         + '&OrderNo=' + rtrim(PolicyFile.OrderNo) + '&Sys=' + PolicyFile.SubIns + '&Branch=' + PolicyFile.Branch AS Pol,
RTRIM(MainClaimFile.ClmNo) + '&EndNo=' + LTRIM(MainClaimFile.EndNo) 
                         + '&LoadNo=' + LTRIM(MainClaimFile.LoadNo) + '&OrderNo=' + rtrim(PolicyFile.OrderNo) + '&Sys=' + PolicyFile.SubIns + '&Branch=' + PolicyFile.Branch + '&PolNo=' + PolicyFile.PolNo  AS PolPath
 from MainClaimFile left outer join Estimation on MainClaimFile.ClmNo=Estimation.clmno and MainClaimFile.PolNo=Estimation.polno
 left outer join esal on MainClaimFile.clmno=esal.clmno and MainClaimFile.Branch=esal.branch left outer join NetPrm on 
 NetPrm.PolNo = rtrim(MainClaimFile.PolNo) + '-' + rtrim(MainClaimFile.ClmNo) and round(Estimation.value,3)=round(netprm.Net,3) left outer join policyfile
 on MainClaimFile.PolNo=PolicyFile.PolNo and MainClaimFile.EndNo=PolicyFile.EndNo left outer join CustomerFile on CustomerFile.CustNo=policyfile.CustNo left outer join BranchInfo on mainclaimfile.Branch=BranchInfo.BranchNo
 where (YEAR(mainclaimfile.ClmSysDate) =YEAR(@ViewDate) or YEAR(Estimation.date) =YEAR(@ViewDate) or YEAR(esal.disd) =YEAR(@ViewDate)) and mainclaimfile.subins=@SubIns 
 order by net,DT desc" >
        <SelectParameters>
          <asp:Parameter Name="SubIns" Type="String" />   
          <asp:ControlParameter Name="ViewDate" ControlID="ASPxDateEdit1"/>
       </SelectParameters>
    </asp:SqlDataSource>
    <asp:SqlDataSource ID="SqlDataSource2" runat="server" 
        ConnectionString="<%$ ConnectionStrings:IMSDBConnectionString %>" 
        ProviderName="System.Data.SqlClient">
    </asp:SqlDataSource>
