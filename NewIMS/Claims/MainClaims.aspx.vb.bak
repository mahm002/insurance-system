    Protected Sub Page_Load(sender As Object, e As EventArgs) Handles Me.Load
        Lo = Me.Session("LogInfo")
        If IsNothing(Lo) Then
            Me.ClientScript.RegisterStartupScript(Me.GetType, "Msg", "alert('لم يتم تسجيل الدخول');", True)
            Response.Write("<script> window.open('../SystemManag/LogIn.aspx?Parent=" & Me.Page.AppRelativeVirtualPath & "','_self'); </script>")
        Else
            Dim Tr As TreeView = Nothing
            ' Tr = Session("Tree")
            'Call SetUserPerm(Tr, Lo, 2)
            Call SetUserPermNAV(ASPxNavBar1, Lo, 2)
            'Dim Lbl1 As Label = Master.Master.FindControl("BannerTitle")
            'Lbl1.Text = Lo(0) & " at " & Format(Now, "hh:mm:ss") & " فرع " & GetBranchName(Lo(7))
            'Dim MenuTable As Table = Master.Master.FindControl("Table1")
            'MenuTable.BackImageUrl = "~/images/GlossyRed.png"
            'Session("Branch") = Lo(7)
        End If

        If Not IsPostBack And Not IsNothing(Lo) Then
            If DatePart("q", Today.Date) = 1 Then
                'Sys.Text = "Q4"
                'Years.Text = Year(Today.Date) - 1
            Else
                'Sys.Text = "Q" + CStr(DatePart("q", Today.Date) - 1)
                'Years.Value = Year(Today.Date)
            End If
        End If

        MainGrid.DataBind()
    End Sub
    Protected Sub chkSingleExpanded_CheckedChanged(ByVal sender As Object, ByVal e As EventArgs)
        MainGrid.SettingsDetail.AllowOnlyOneMasterRowExpanded = chkSingleExpanded.Checked
        If MainGrid.SettingsDetail.AllowOnlyOneMasterRowExpanded Then
            MainGrid.DetailRows.CollapseAllRows()
        End If
        MainGrid.DataBind()
    End Sub
