<asp:Content  ID="Content2" ContentPlaceHolderID="NAV" Runat="Server" >
    <dx:ASPxNavBar Width="194px" Height="100%" ID="ASPxNavBar1" Font-Names="tahoma"  ItemStyle-Font-Size="8"
